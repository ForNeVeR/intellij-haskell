<idea-plugin>
    <extensions defaultExtensionNs="com.intellij">
        <spellchecker.support language="Haskell"
                              implementationClass="me.fornever.haskeletor.spellchecker.HaskellSpellcheckingStrategy"/>
        <spellchecker.support language="Cabal"
                              implementationClass="me.fornever.haskeletor.spellchecker.CabalSpellcheckingStrategy"/>
        <spellchecker.bundledDictionaryProvider
            implementation="me.fornever.haskeletor.spellchecker.HaskellBundledDictionaryProvider"/>
    </extensions>
</idea-plugin>
