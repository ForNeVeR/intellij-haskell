<idea-plugin require-restart="true">
    <id>me.fornever.haskeletor</id>
    <name>Haskeletor</name>
    <vendor email="friedrich@fornever.me">Friedrich von Never</vendor>

    <description><![CDATA[
        <p> Haskell language support.</p>
        <ul>
            <li>This plugin depends mainly on Stack.</li>
            <li>It can create new Stack projects and import existing Stack projects.</li>
            <li>Please <a href="https://github.com/ForNeVeR/haskeletor/blob/HEAD/README.md">README</a>.</li>
        </ul>
        <p>This plugin is based on <a href="https://github.com/rikvdkleij/intellij-haskell">the work of Rik van der Kleij and intellij-haskell contributors</a>.</p>
    ]]></description>

    <depends optional="true"
             config-file="me.fornever.haskeletor.spellchecker.xml">com.intellij.modules.spellchecker</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File types -->
        <fileType name="Alex"
                  language="Alex"
                  implementationClass="me.fornever.haskeletor.alex.AlexFileType"
                  extensions="x"
                  fieldName="INSTANCE"/>

        <fileType name="Cabal"
                  language="Cabal"
                  implementationClass="me.fornever.haskeletor.cabal.CabalFileType"
                  extensions="cabal"
                  fieldName="INSTANCE"/>

        <fileType name="Haskell"
                  language="Haskell"
                  implementationClass="me.fornever.haskeletor.HaskellFileType"
                  extensions="hs"
                  fieldName="INSTANCE"/>

        <!-- Parser -->
        <lang.parserDefinition language="Haskell" implementationClass="me.fornever.haskeletor.HaskellParserDefinition"/>
        <lang.parserDefinition language="Cabal"
                               implementationClass="me.fornever.haskeletor.cabal.lang.parser.CabalParserDefinition"/>
        <lang.parserDefinition language="Alex"
                               implementationClass="me.fornever.haskeletor.alex.lang.parser.AlexParserDefinition"/>

        <!-- Syntax Highlighter -->
        <lang.syntaxHighlighterFactory language="Haskell"
                                       implementationClass="me.fornever.haskeletor.highlighter.HaskellSyntaxHighlighterFactory"/>
        <lang.syntaxHighlighterFactory language="Cabal"
                                       implementationClass="me.fornever.haskeletor.cabal.highlighting.CabalSyntaxHighlighterFactory"/>
        <lang.syntaxHighlighterFactory language="Alex"
                                       implementationClass="me.fornever.haskeletor.alex.highlighting.AlexSyntaxHighlighterFactory"/>

        <!-- Refactoring support -->
        <lang.refactoringSupport language="Haskell"
                                 implementationClass="me.fornever.haskeletor.refactor.HaskellRefactoringSupportProvider"/>
        <moveFileHandler implementation="me.fornever.haskeletor.refactor.HaskellMoveFileHandler"/>
        <renamePsiElementProcessor implementation="me.fornever.haskeletor.refactor.HaskellRenameFileProcessor"/>
        <renamePsiElementProcessor implementation="me.fornever.haskeletor.refactor.HaskellRenameVariableProcessor"/>
        <renameInputValidator implementation="me.fornever.haskeletor.refactor.HaskellRenameInputValidator"/>
        <lang.elementManipulator forClass="me.fornever.haskeletor.psi.HaskellNamedElement"
                                 implementationClass="me.fornever.haskeletor.psi.HaskellNamedElementManipulator"/>
        <lang.elementManipulator forClass="me.fornever.haskeletor.alex.lang.psi.impl.AlexHaskellCodeInjectionHost"
                                 implementationClass="me.fornever.haskeletor.alex.lang.psi.impl.AlexElementManipulator"/>
        <lang.elementManipulator forClass="me.fornever.haskeletor.psi.impl.HaskellStringLiteralElementImpl"
                                 implementationClass="me.fornever.haskeletor.psi.impl.HaskellStringLiteralManipulator"/>
        <lang.elementManipulator forClass="me.fornever.haskeletor.psi.impl.HaskellQuasiQuoteElementImpl"
                                 implementationClass="me.fornever.haskeletor.psi.impl.HaskellQuasiQuoteManipulator"/>
        <lang.namesValidator language="Haskell" implementationClass="me.fornever.haskeletor.refactor.HaskellNamesValidator"/>
        <languageInjector implementation="me.fornever.haskeletor.alex.lang.psi.AlexHaskellInjector"/>

        <lang.elementManipulator forClass="me.fornever.haskeletor.cabal.lang.psi.CabalNamedElement"
                                 implementationClass="me.fornever.haskeletor.cabal.lang.psi.CabalNamedElementManipulator"/>

        <!-- Folding -->
        <lang.foldingBuilder language="Haskell"
                             implementationClass="me.fornever.haskeletor.editor.HaskellFoldingBuilder"/>
        <applicationService serviceImplementation="me.fornever.haskeletor.editor.HaskellFoldingSettings"/>
        <codeFoldingOptionsProvider instance="me.fornever.haskeletor.editor.HaskellCodeFoldingOptionsProvider"/>

        <!-- Commenter -->
        <lang.commenter language="Haskell" implementationClass="me.fornever.haskeletor.editor.HaskellCommenter"/>
        <lang.commenter language="Cabal" implementationClass="me.fornever.haskeletor.cabal.CabalCommenter"/>

        <!-- Matcher -->
        <lang.braceMatcher language="Haskell"
                           implementationClass="me.fornever.haskeletor.highlighter.HaskellBraceMatcher"/>
        <lang.braceMatcher language="Alex"
                           implementationClass="me.fornever.haskeletor.alex.lang.AlexBraceMatcher"/>

        <!-- Doc-Provider -->
        <lang.documentationProvider language="Haskell"
                                    implementationClass="me.fornever.haskeletor.external.component.HaskellDocumentationProvider"/>

        <!-- Quick definition -->
        <lang.implementationTextSelectioner language="Haskell"
                                            implementationClass="me.fornever.haskeletor.codeinsight.HaskellImplementationTextSelectioner"/>

        <!-- Structure View -->
        <lang.psiStructureViewFactory language="Haskell"
                                      implementationClass="me.fornever.haskeletor.navigation.HaskellStructureViewFactory"/>

        <!-- Usages Provider -->
        <lang.findUsagesProvider language="Haskell"
                                 implementationClass="me.fornever.haskeletor.navigation.HaskellFindUsagesProvider"/>

        <!-- Navigation -->
        <gotoClassContributor implementation="me.fornever.haskeletor.navigation.GotoByDeclarationContributor"/>
        <gotoSymbolContributor implementation="me.fornever.haskeletor.navigation.GotoByNameContributor"/>

        <!-- Test Integration -->
        <testFinder implementation="me.fornever.haskeletor.testIntegration.HaskellTestFinder"/>
        <testCreator language="Haskell" implementationClass="me.fornever.haskeletor.testIntegration.HaskellTestCreator"/>

        <!-- Annotator -->
        <externalAnnotator language="Haskell"
                           implementationClass="me.fornever.haskeletor.annotator.HaskellAnnotator"/>
        <annotator language="Haskell"
                   implementationClass="me.fornever.haskeletor.highlighter.HaskellHighlightingAnnotator"/>
        <annotator language="Cabal"
                   implementationClass="me.fornever.haskeletor.cabal.highlighting.CabalAnnotator"/>

        <!-- Completion -->
        <completion.contributor language="Haskell"
                                implementationClass="me.fornever.haskeletor.editor.HaskellCompletionContributor"/>
        <completion.contributor
                language="Cabal"
                implementationClass="me.fornever.haskeletor.cabal.completion.CabalCompletionContributor"/>
        <lookup.charFilter implementation="me.fornever.haskeletor.editor.HaskellCompletionCharFilter"/>
        <psi.referenceContributor language="Haskell" implementation="me.fornever.haskeletor.psi.HaskellReferenceContributor"/>
        <liveTemplateContext implementation="me.fornever.haskeletor.editor.HaskellTemplateContextType"/>
        <liveTemplateContext implementation="me.fornever.haskeletor.editor.HaskellPragmaTemplateContextType"/>
        <liveTemplateContext implementation="me.fornever.haskeletor.editor.HaskellGlobalDefinitionTemplateContextType"/>
        <defaultLiveTemplates file="liveTemplates/Haskell"/>
        <!-- Handler -->
        <typedHandler implementation="me.fornever.haskeletor.editor.HaskellTypedHandler" id="HaskellFile"/>
        <extendWordSelectionHandler implementation="me.fornever.haskeletor.editor.HaskellExtendWordSelectionHandler"/>
        <enterHandlerDelegate implementation="me.fornever.haskeletor.editor.EnterInHaddockHandler"
                              id="EnterInHaddockHandler"/>
        <enterHandlerDelegate implementation="me.fornever.haskeletor.editor.IndentAfterEnterHandler"
                              id="IndentAfterEnterHandler"/>

        <quoteHandler fileType="Haskell" className="me.fornever.haskeletor.editor.HaskellQuoteHandler"/>

        <!-- Code Style -->
        <codeStyleSettingsProvider
                implementation="me.fornever.haskeletor.editor.formatter.settings.HaskellCodeStyleSettingsProvider"/>
        <langCodeStyleSettingsProvider
                implementation="me.fornever.haskeletor.editor.formatter.settings.HaskellLanguageCodeStyleSettingsProvider"/>

        <!-- Color Setting -->
        <colorSettingsPage implementation="me.fornever.haskeletor.highlighter.HaskellColorSettingsPage"/>
        <colorSettingsPage implementation="me.fornever.haskeletor.cabal.highlighting.CabalColorSettingsPage"/>
        <colorSettingsPage implementation="me.fornever.haskeletor.alex.highlighting.AlexColorSettingsPage"/>

        <!-- Inspection -->
        <localInspection language="Haskell" shortName="HLintInspection"
                         displayName="Inspection by HLint"
                         groupName="Haskell" enabledByDefault="true" level="WARNING"
                         implementationClass="me.fornever.haskeletor.inspection.HLintInspectionTool"/>

        <!-- Intention -->
        <intentionAction>
            <className>me.fornever.haskeletor.intention.AddParensIntention</className>
            <category>Haskell</category>
        </intentionAction>
        <intentionAction>
            <className>me.fornever.haskeletor.intention.RemoveParensIntention</className>
            <category>Haskell</category>
        </intentionAction>
        <intentionAction>
            <className>me.fornever.haskeletor.intention.CaseSplitIntention</className>
            <category>Haskell</category>
        </intentionAction>


        <!-- Stack -->
        <sdkType implementation="me.fornever.haskeletor.sdk.HaskellSdkType"/>

        <!-- Index -->
        <fileBasedIndex implementation="me.fornever.haskeletor.util.index.HaskellModuleNameIndex"/>
        <stubIndex implementation="me.fornever.haskeletor.psi.stubs.index.HaskellAllNameIndex"/>
        <stubElementTypeHolder class="me.fornever.haskeletor.psi.HaskellTypes"/>

        <!-- Configuration -->
        <applicationConfigurable groupId="language"
                                 id="Haskell.Configurable"
                                 instance="me.fornever.haskeletor.settings.HaskellConfigurable"
                                 bundle="messages.HaskeletorBundle"
                                 key="configurable.haskell.title"/>
        <applicationService serviceImplementation="me.fornever.haskeletor.settings.HaskellSettingsPersistentStateComponent"/>
        <lang.importOptimizer language="Haskell" implementationClass="me.fornever.haskeletor.editor.HaskellImportOptimizer"/>

        <!-- Module -->
        <internalFileTemplate name="Haskell Module"/>
        <internalFileTemplate name="Alex Source"/>
        <internalFileTemplate name="Haskell Test Module"/>
        <moduleType id="HASKELL_MODULE" implementationClass="me.fornever.haskeletor.module.HaskellModuleType"/>

        <!-- Runner -->
        <actionPromoter implementation="me.fornever.haskeletor.runconfig.console.HaskellConsoleActionPromoter"/>
        <configurationType implementation="me.fornever.haskeletor.runconfig.HaskellStackConfigurationType"/>
        <!-- Notification -->
        <editorNotificationProvider
                implementation="me.fornever.haskeletor.notification.ConfigFileWatcherNotificationProvider"/>
        <projectSdkSetupValidator implementation="me.fornever.haskeletor.notification.HaskellProjectSdkSetupValidator"/>

        <!-- Mover -->
        <!--<statementUpDownMover implementation="me.fornever.haskeletor.editor.HaskellStatementMover"/>-->

        <checkinHandlerFactory implementation="me.fornever.haskeletor.action.HaskellReformatCheckinHandlerFactory"/>
        <checkinHandlerFactory implementation="me.fornever.haskeletor.action.HaskellOptimizeImportsCheckinHandlerFactory"/>

        <applicationService serviceInterface="com.intellij.codeInsight.TargetElementUtil"
                            serviceImplementation="me.fornever.haskeletor.navigation.HaskellTargetElementUtil"
                            overrides="true"/>

        <targetElementEvaluator language="Haskell"
                                implementationClass="me.fornever.haskeletor.navigation.HaskellTargetElementUtil2"/>

    </extensions>

    <application-components>
        <!-- Add your application components here -->
    </application-components>

    <project-components><component><implementation-class>me.fornever.haskeletor.external.component.StackProjectManager</implementation-class></component><component><implementation-class>me.fornever.haskeletor.external.component.HaskellDocumentationProvider</implementation-class></component></project-components>

    <actions>
        <action id="Haskell.HaskellFile" class="me.fornever.haskeletor.action.CreateHaskellFileAction"
                text="Haskell Module" description="Create new Haskell module">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFile"/>
        </action>

        <action id="Haskell.AlexFile" class="me.fornever.haskeletor.alex.NewAlexFileAction">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFile"/>
        </action>

        <group id="HaskellCodeEditor" text="Haskell" description="Haskell View Tools" icon="me.fornever.haskeletor.icons.HaskellIcons.HaskellLogo"
               popup="true">
            <action id="Haskell.ShowType" class="me.fornever.haskeletor.action.ShowTypeAction"
                    text="Show Type" description="Show type of (selected) expression">

                <keyboard-shortcut first-keystroke="alt EQUALS" keymap="$default"/>
                <keyboard-shortcut first-keystroke="alt EQUALS" keymap="Mac OS X" remove="true"/>
                <keyboard-shortcut first-keystroke="alt EQUALS" keymap="Mac OS X 10.5+" remove="true"/>
                <keyboard-shortcut first-keystroke="ctrl alt p" keymap="Mac OS X"/>
                <keyboard-shortcut first-keystroke="ctrl alt p" keymap="Mac OS X 10.5+"/>
            </action>

            <action id="Haskell.ShowTypeSticky" class="me.fornever.haskeletor.action.ShowTypeStickyAction"
                    text="Show Type (Sticky)" description="Show type of (selected) expression (Sticky)">

                <keyboard-shortcut first-keystroke="ctrl alt g" keymap="$default"/>
                <keyboard-shortcut first-keystroke="ctrl alt g" keymap="Mac OS X"/>
                <keyboard-shortcut first-keystroke="ctrl alt g" keymap="Mac OS X 10.5+"/>
            </action>

            <action id="Haskell.ShowInfo" class="me.fornever.haskeletor.action.ShowNameInfoAction"
                    text="Show Info" description="Show info about identifier in context of file">

                <keyboard-shortcut first-keystroke="alt shift EQUALS" keymap="$default"/>
                <keyboard-shortcut first-keystroke="alt shift EQUALS" keymap="Mac OS X" remove="true"/>
                <keyboard-shortcut first-keystroke="alt shift EQUALS" keymap="Mac OS X 10.5+" remove="true"/>
                <keyboard-shortcut first-keystroke="ctrl shift p" keymap="Mac OS X"/>
                <keyboard-shortcut first-keystroke="ctrl shift p" keymap="Mac OS X 10.5+"/>
            </action>

            <action id="Haskell.ShowErrorDescription"
                    class="me.fornever.haskeletor.action.ShowProblemMessageAction"
                    text="Show Error" description="Show error/warning description">
                <keyboard-shortcut first-keystroke="ctrl F10" keymap="$default"/>
                <keyboard-shortcut first-keystroke="meta F10" keymap="Mac OS X"/>
                <keyboard-shortcut first-keystroke="meta F10" keymap="Mac OS X 10.5+"/>
            </action>

            <action id="Haskell.Hoogle.It"
                    class="me.fornever.haskeletor.action.HoogleAction"
                    text="Hoogle For It"
                    description="Hoogle for (selected) words">
                <keyboard-shortcut first-keystroke="shift ctrl h" keymap="$default"/>
            </action>
            <add-to-group group-id="CodeEditorViewGroup" anchor="last"/>
        </group>

        <group id="HaskellGhciMenu" text="GHCi" description="GHCi" popup="true" keep-content="true">
            <action id="Haskell.SendToGhci" class="me.fornever.haskeletor.action.ghci.SendToConsoleAction"
                    text="Send to GHCi" description="Execute selected command in GHCi"/>

            <action id="Haskell.Ghci.LoadModule" class="me.fornever.haskeletor.action.ghci.LoadModuleAction"
                    text="Load module in GHCi" description="Load currently selected module in GHCi"/>

            <action id="Haskell.Ghci.ReloadModules" class="me.fornever.haskeletor.action.ghci.ReloadModulesAction"
                    text="Reload modules in GHCi" description="Reload the current module set in GHCi"/>

            <action id="Haskell.Ghci.ReloadWithLastCommand"
                    class="me.fornever.haskeletor.action.ghci.ReloadWithLastCommandAction"
                    text="Reload GHCi with last command" description="Re-execute last command after reloading modules"/>
        </group>

        <group id="HaskellMenu" text="Haskell" description="Haskell Tools" icon="me.fornever.haskeletor.icons.HaskellIcons.HaskellLogo"
               keep-content="true">
            <action id="Haskell.RestartStackRepl" class="me.fornever.haskeletor.action.RestartStackReplsAction"
                    text="Update Settings and restart REPLs"
                    description="Update Module Settings and restart REPLs">
            </action>

            <action id="Haskell.BuildHoogleDatabase" class="me.fornever.haskeletor.action.BuildHoogleDbAction"
                    text="(Re)Build Hoogle database"
                    description="(Re)Generate Haskell documentation and (re)build local Hoogle database">
            </action>

            <action id="Haskell.UpdateHaskellTools" class="me.fornever.haskeletor.action.UpdateHaskellToolsAction"
                    text="Update Haskell Tools"
                    description="Update Haskell Tools with latest version of LTS-12">
            </action>

            <add-to-group group-id="MainMenu" anchor="before" relative-to-action="HelpMenu"/>
            <separator/>
            <reference id="HaskellGhciMenu"/>
        </group>


        <group id="HaskellCodeMenu" text="Haskell" description="Haskell Code Tools" icon="me.fornever.haskeletor.icons.HaskellIcons.HaskellLogo"
               popup="true">

            <action id="Haskell.ReformatCode"
                    class="me.fornever.haskeletor.action.OrmoluReformatAction"
                    text="Reformat Code by Ormolu"
                    description="Reformat code by Ormolu">
                <keyboard-shortcut first-keystroke="ctrl alt SEMICOLON" keymap="$default"/>
            </action>

            <action id="Haskell.StylishHaskellFormat"
                    class="me.fornever.haskeletor.action.StylishHaskellReformatAction"
                    text="Reformat Code by Stylish-Haskell"
                    description="Reformat current file by Stylish-Haskell">
                <keyboard-shortcut first-keystroke="ctrl alt u" keymap="$default"/>
            </action>

            <add-to-group group-id="CodeMenu" anchor="last"/>
        </group>

        <group id="HaskellGoToMenu" text="Haskell" description="Haskell Goto Tools" icon="me.fornever.haskeletor.icons.HaskellIcons.HaskellLogo"
               popup="true">
            <action id="Haskell.Hoogle.Navigation"
                    class="me.fornever.haskeletor.action.HoogleNavigationAction"
                    text="Navigation by Hoogle"
                    description="Navigation powered by Hoogle">
                <keyboard-shortcut first-keystroke="shift alt h" keymap="$default"/>
            </action>

            <action id="Haskell.GotoInstanceDeclaration"
                    class="me.fornever.haskeletor.action.GotoInstanceDeclarationAction"
                    text="Instance Declaration"
                    description="Goto instance declaration">
                <keyboard-shortcut first-keystroke="ctrl alt i" keymap="$default"/>
            </action>
            <add-to-group group-id="GoToMenu" anchor="last"/>
        </group>

        <action id="Haskell.Project.About"
                class="me.fornever.haskeletor.action.AboutAction"
                text="About Haskell Project"
                icon="me.fornever.haskeletor.icons.HaskellIcons.HaskellLogo"
                description="About Haskell GHC/tools used in project">
            <add-to-group group-id="HelpMenu" anchor="last"/>
        </action>


        <group id="Haskell.Runconfig">
            <action id="Haskell.ConsoleExecute"
                    class="me.fornever.haskeletor.runconfig.console.HaskellConsoleExecuteAction">
                <keyboard-shortcut first-keystroke="ENTER" keymap="$default"/>
            </action>
        </group>
    </actions>
</idea-plugin>
